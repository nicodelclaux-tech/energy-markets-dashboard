# API keys — copy this file to .env and fill in your keys
# .env is gitignored and never committed

# ENTSO-E Transparency Platform
# Register at: https://transparency.entsoe.eu/usrm/user/createPublicUser
ENTSOE_API_KEY=your_entsoe_api_key_here

# Financial Modeling Prep (free tier)
# Register at: https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_api_key_here

# US Energy Information Administration (EIA)
# Register at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# The Guardian Open Platform (free tier)
# Register at: https://open-platform.theguardian.com/access/
GUARDIAN_API_KEY=your_guardian_api_key_here

# Ember Climate API (optional — public datasets work without a key)
EMBER_API_KEY=

# Alpha Vantage (free tier with API key)
# Register at: https://www.alphavantage.co/support/#api-key
# Used for: gold, silver, copper prices and news/sentiment
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# GIE / AGSI + ALSI API key
# Register / request access at: https://www.gie.eu/transparency-platform/GIE_API_documentation_v007.pdf
# or via: https://agsi.gie.eu (for gas storage) and https://alsi.gie.eu (for LNG)
# Used for: European gas storage levels, % full, trend, and LNG terminal inventory
GIE_API_KEY=your_gie_api_key_here
